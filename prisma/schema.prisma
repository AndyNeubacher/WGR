generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OcrStatus {
  pending
  done
  failed
}

enum JobStatus {
  pending
  running
  done
  failed
}

enum UserRole {
  technician
  manager
}

model Reading {
  id             String    @id @default(uuid()) @db.Char(36)
  primaryPhotoId String?   @unique @db.Char(36)
  primaryPhoto   Photo?    @relation("ReadingPrimary", fields: [primaryPhotoId], references: [id], onDelete: SetNull)
  serialNumber   String?   @db.VarChar(64)
  consumedVolume Decimal?  @db.Decimal(12, 3)
  ocrStatus      OcrStatus @default(pending)
  ocrRawJson     Json?
  technicianNote String?   @db.Text
  createdAt      DateTime  @default(now())
  verifiedAt     DateTime?

  gaugeId      String? @db.Char(36)
  gauge        Gauge?  @relation("GaugeReadings", fields: [gaugeId], references: [id], onDelete: SetNull)
  technicianId String? @db.Char(36)

  photos Photo[] @relation("ReadingPhotos")

  @@index([createdAt])
  @@map("readings")
}

model Photo {
  id        String   @id @default(uuid()) @db.Char(36)
  readingId String   @db.Char(36)
  reading   Reading  @relation("ReadingPhotos", fields: [readingId], references: [id], onDelete: Cascade)
  path      String   @db.VarChar(255)
  caption   String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  primaryFor Reading? @relation("ReadingPrimary")

  @@index([readingId])
  @@map("photos")
}

model Job {
  id          String    @id @default(uuid()) @db.Char(36)
  type        String    @db.VarChar(64)
  payloadJson Json
  status      JobStatus @default(pending)
  attempts    Int       @default(0)
  runAt       DateTime  @default(now())
  lockedBy    String?   @db.VarChar(64)
  lockedUntil DateTime?
  lastError   String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@map("jobs")
}

model Note {
  id         String   @id @default(uuid()) @db.Char(36)
  targetType String   @db.VarChar(32) // 'photo', 'serialNumber', 'gauge', 'site'
  targetId   String   @db.Char(36)
  body       String   @db.Text
  authorId   String   @db.Char(36)
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@map("notes")
}

model User {
  id           String   @id @default(uuid()) @db.Char(36)
  name         String   @db.VarChar(128)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(technician)
  createdAt    DateTime @default(now())

  assignments TechnicianGauge[]

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())

  sites Site[]

  @@map("customers")
}

model Site {
  id         String   @id @default(uuid()) @db.Char(36)
  customerId String   @db.Char(36)
  customer   Customer @relation(fields: [customerId], references: [id])
  name       String   @db.VarChar(255)
  address    String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  gauges Gauge[]

  @@index([customerId])
  @@map("sites")
}

model Gauge {
  id        String   @id @default(uuid()) @db.Char(36)
  siteId    String   @db.Char(36)
  site      Site     @relation(fields: [siteId], references: [id])
  label     String   @db.VarChar(255)
  createdAt DateTime @default(now())

  readings    Reading[]         @relation("GaugeReadings")
  assignments TechnicianGauge[]

  @@index([siteId])
  @@map("gauges")
}

model TechnicianGauge {
  technicianId String   @db.Char(36)
  gaugeId      String   @db.Char(36)
  assignedAt   DateTime @default(now())

  technician User  @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  gauge      Gauge @relation(fields: [gaugeId], references: [id], onDelete: Cascade)

  @@id([technicianId, gaugeId])
  @@map("technician_gauges")
}
